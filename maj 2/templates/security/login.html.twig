<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge" />
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
        <meta name="description" content="" />
        <meta name="author" content="" />
        <title>GESTION de Verification</title>
        {% block stylesheets %}
            <link rel="stylesheet" href="{{ asset('dist/css/styles.css') }}">
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" crossorigin="anonymous">
        {% endblock %}

    </head>
    <body style="background: linear-gradient(90deg,rgba(28, 128, 199, 1) 0%, rgba(240, 152, 58, 1) 100%);
">
        <div id="layoutAuthentication" >
            <div style = " margin: 0 0 155px 0; ">
                <main>
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-5">
                                <div class="card shadow-lg border-0 rounded-lg mt-5">
                                    <div class="card-header"><h3 class="text-center font-weight-light my-4">Connexion</h3></div>
                                    <div class="card-body">
                                        <form method="post">
                                            {% if error %}
                                                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                                            {% endif %}

                                            {% if app.user %}
                                                <div class="mb-3">
                                                    Vous êtes connectés {{ app.user.nom }}, <a href="{{ path('app_logout') }}">Deconnexion</a>
                                                </div>
                                            {% endif %}

                                            <h1 class="h3 mb-3 font-weight-normal">Veuillez vous connecter</h1>
                                            <label for="username">Email</label>
                                            <input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>
                                            <label for="password">Password</label>
                                            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>

                                            <input type="hidden" name="_csrf_token"  value="{{ csrf_token('authenticate') }}">

                                            {#
                                            Uncomment this section and add a remember_me option below your firewall to activate remember me functionality.
                                            See https://symfony.com/doc/current/security/remember_me.html

                                            <div class="checkbox mb-3">
                                                <label>
                                                    <input type="checkbox" name="_remember_me"> Remember me
                                                </label>
                                            </div>
                                            #}
                                            <hr style="visibility: hidden" />

                                            <button class="btn btn-lg btn-primary" style="margin:0 0 0 180px;" type="submit">
                                                Connexion
                                            </button>     

                                        </form>
                                    </div>
                                    <div class="card-footer text-center py-3" >
                                        <div class="small"><a href="{{ path('app_user_new') }}">Pas de compte, Inscrivez-vous!</a></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
            {# <div>
                <footer class="py-4 bg-light mt-auto">
                    <div class="container-fluid px-4">
                        <div class="d-flex align-items-center justify-content-between small">
                            <div class="text-muted" style="padding: auto;">BIENVENUE SUR SOCAF PESAGE</div>
                        </div>
                    </div>
                </footer>
            </div> #}
        </div>
        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
            <script src="{{ asset('src/js/scripts.js') }}"></script>
        {% endblock %}
    </body>
</html>
