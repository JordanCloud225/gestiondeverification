{% extends 'base.html.twig' %}

{% block title %}controledexcentration{% endblock %}

{% block body %}
 <div class="row">
              <div class="col-md-12">
              <a href="{{ path('app_controledexcentration_create')}}"><button class="btn btn-secondary"><span class="btn-label"><i class="fa fa-plus"></i></span>Nouveau controle d'excentration</button></a>
                <div class="card">
                  <div class="card-header">
                    <div class="d-flex align-items-center">
                      <h4 class="card-title">Liste des controle d'excentration</h4>
                    </div>
                  </div>
                  <div class="card-body">
                    <!-- Modal -->
                 

                    <div class="table-responsive">
                      <table class="display table table-striped table-hover">
                        <thead>
                          <tr>
                            <th>Code instrument</th>                            
                            <th>N° position</th>
                            <th>Valeur nominale</th>
                            <th>indication lue</th>
                            <th>indication surcharge</th>
                            <th>ecart releve</th>
                            <th style="width: 10%">Action</th>
                          </tr>
                        </thead>
                        <tfoot>
                          <tr>
                            <th>Code instrument</th>                            
                            <th>N° Position</th>
                            <th>Valeur nominale</th>
                            <th>Indicationlue</th>
                            <th>Indication surcharge</th>
                            <th>Ecart releve</th>
                            <th style="width: 10%">Action</th>                         
                          </tr>
                        </tfoot>
                        <tbody>
                         {% for controledexcentrations in controledexcentration %}
                        <tr>
                             <td>{{ controledexcentrations.instrument ? controledexcentrations.instrument.codeinstrument }}</td>
                             <td>{{ controledexcentrations.numposition}}</td>
                             <td>{{ controledexcentrations.valeurnominale}}</td>
                             <td>{{ controledexcentrations.indicationlue}}</td>
                             <td>{{ controledexcentrations.indicationsurcharge	}}</td>
                             <td>{{ controledexcentrations.ecartreleve}}</td>
                            <td>
                              <div class="form-button-action">
                                <button class="btn btn-link btn-primary btn-lg">
                                  <a href="{{ path('app_controledexcentration_edit', {'id': controledexcentrations.id})}}"><i class="fa fa-edit"></i></a>
                                </button> 
                                <button class="btn btn-link btn-danger btn-lg">
                                  <a href="{{ path('app_controledexcentration_delete', {'id': controledexcentrations.id})}}" ><i class="fa fa-trash"></i></a>
                                </button>
                              </div>
                            </td>
                        </tr>
                           {% endfor %}
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
{% endblock %}

