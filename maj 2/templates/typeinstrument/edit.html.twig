{% extends 'base.html.twig' %}

{% block title %}type d'instrument{% endblock %}

{% block body %}  
<br>
<div class="card card-round">
    <div class="card-header">
      <div class="card-head-row">
        <div class="card-title">Formulaire de modification d'un type d'instrument</div>
      </div>
    </div>
    <div class="card-body">
      <div class="row">
          <div class="col-md-6 col-lg-4">
              {{ form_start(form) }}
            <div class="form-group">
              <label >Libelle</label>
            {{ form_widget(form.libelle) }}
            </div>
          </div>                      
          <div class="form-group mt-3">
            <div class="col-sm-offset-2 col-sm-10">
                <button type="submit" class="btn btn-success">{{ button_label|default('Modifier') }}</button>
                <a href="{{ path('app_typeinstrument') }}" class="btn btn-danger">Revenir</a>
            </div>
          </div> 
      </div>
    </div>   
    {{ form_end(form) }}                                
</div>

{% endblock %}
