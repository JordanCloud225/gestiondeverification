{% extends 'base.html.twig' %}

{% block title %}Tolerance{% endblock %}

{% block body %}  
<br>
<div class="card card-round">
    <div class="card-header">
      <div class="card-head-row">
        <div class="card-title">Formulaire d'ajout d'une tolérance</div>
      </div>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 col-lg-4">
            {{ form_start(form) }}
          <div class="form-group">
            <label >Valeur en KG</label>
            {{ form_widget(form.valeur) }}
          </div> 
          {{ form_end(form) }}
        </div>            
      </div>
      <div class="form-group mt-3">
        <div class="col-sm-offset-2 col-sm-10">
            <button type="submit" class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
            <a href="{{ path('app_tolerance') }}" class="btn btn-danger">Revenir</a>
        </div>
      </div> 
    </div>                                 
</div>
{% endblock %}
