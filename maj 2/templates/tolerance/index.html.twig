{% extends 'base.html.twig' %}

{% block title %}client{% endblock %}

{% block body %}
 <div class="row">
              <div class="col-md-12">
              <a href="{{ path('app_tolerance_create')}}"><button class="btn btn-secondary"><span class="btn-label"><i class="fa fa-plus"></i></span>Nouvelle tolérance</button></a>
                <div class="card">
                  <div class="card-header">
                    <div class="d-flex align-items-center">
                      <h4 class="card-title">Liste des tolerance</h4>
                    </div>
                  </div>
                  <div class="card-body">
                    <!-- Modal -->
                 

                    <div class="table-responsive">
                      <table class="display table table-striped table-hover">
                        <thead>
                          <tr>
                            <th>Valeur</th>
                            <th>Unité de mesure</th>
                            <th style="width: 10%">Action</th>
                          </tr>
                        </thead>
                        <tfoot>
                          <tr>
                           <th>Valeur</th>
                            <th>Unité de mesure</th>
                            <th style="width: 10%">Action</th>                         
                          </tr>
                        </tfoot>
                        <tbody>
                         {% for tolerances in tolerance %}
                        <tr>
                             <td>{{ tolerances.valeur}}</td>
                             <td>{{ tolerances.unitemesure}}</td>
                             <td>
                              <div class="form-button-action">
                                <button class="btn btn-link btn-primary btn-lg">
                                  <a href="{{ path('app_tolerance_edit',{'id': tolerances.id})}}"><i class="fa fa-edit"></i></a>
                                </button> 
                                <button class="btn btn-link btn-danger btn-lg">
                                  <a href="{{ path('app_tolerance_delete',{'id': tolerances.id})}}"><i class="fa fa-trash"></i></a>
                                </button>
                              </div>

                            </td>

                        </tr>
                        {% endfor %}

                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
{% endblock %}

