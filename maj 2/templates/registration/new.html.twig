
{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<br>
<div class="card card-round">
    <div class="card-header">
      <div class="card-head-row">
        <div class="card-title">Formulaire d'ajout d'un utilisateur</div>
      </div>
    </div>
   <div class="card-body">
    <div class="row">
      <div class="col-md-6 col-lg-4">
          {{ form_start(form) }}
          <div class="form-group">
            <label for="password">Nom</label>
              {{ form_widget(form.nom) }}
          </div>
          <div class="form-group">
            <label for="email2">Email</label>
            {{ form_widget(form.email) }}
          </div>
      </div>
      <div class="col-md-6 col-lg-4">
        <div class="form-group">
          <label for="email2">Contact</label>
          {{ form_widget(form.contact) }}
        </div>   
        <div class="form-group">
            {{ form_widget(form.plainPassword) }}
        </div>     
      </div>       
       <div class="col-md-6 col-lg-4">
        <div class="form-group">
          <label class="col-md-3 col-form-label">Rôles</label>
            {{ form_widget(form.roles) }}
        </div>
      </div> 
      <div class="form-group mt-3">
        <div class="col-sm-offset-2 col-sm-10">
            <button type="submit" class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>
            <a href="{{ path('app_register_index') }}" class="btn btn-danger">Revenir</a>
        </div>
        {{ form_end(form) }}
      </div> 
    </div>
  </div>
</div>
{% endblock %}
