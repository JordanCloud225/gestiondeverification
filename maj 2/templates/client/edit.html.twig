{% extends 'base.html.twig' %}

{% block title %}client{% endblock %}

{% block body %}  
<br>
<div class="card card-round">
    <div class="card-header">
      <div class="card-head-row">
        <div class="card-title">Formulaire de modification d'un client</div>
      </div>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 col-lg-4">
            {{ form_start(form) }}
          <div class="form-group">
            <label >Nom</label>
            {{ form_widget(form.nom) }}
          </div>
        </div> 
        <div class="col-md-6 col-lg-4">
          <div class="form-group">
            <label >Ville</label>
            {{ form_widget(form.ville) }}
          </div>
        </div>                      
      </div>
      <div class="form-group mt-3">
        <div class="col-sm-offset-2 col-sm-10">
          <button type="submit" class="btn btn-success">{{ button_label|default('Modifier') }}</button>
          <a href="{{ path('app_client') }}" class="btn btn-danger">Revenir</a>
        </div>
      </div> 
    </div> 
</div>

{% endblock %}
