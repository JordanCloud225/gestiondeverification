
{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}
<br>
<div class="card card-round">
    <div class="card-header">
      <div class="card-head-row">
        <div class="card-title">Formulaire d'ajout d'une entreprise</div>
      </div>
    </div>
   <div class="card-body">
    <div class="row">
      <div class="col-md-6 col-lg-4">
          {{ form_start(form) }}
          <div class="form-group">
            <label for="password">libelle</label>
              {{ form_widget(form.libelle) }}
          </div>
          <div class="form-group">
            <label for="email2">siteweb</label>
            {{ form_widget(form.siteweb) }}
          </div>
          <div class="form-group">
            <label for="email2">accreditation</label>
            {{ form_widget(form.accreditation) }}
          </div>
          <div class="form-group">
            <label for="email2">norme</label>
            {{ form_widget(form.norme) }}
          </div>
          <div class="form-group">
            <label for="email2">service</label>
            {{ form_widget(form.service) }}
          </div>
      </div>
    <div class="col-md-6 col-lg-4">
        <div class="form-group">
          <label for="email2">logo</label>
          {{ form_widget(form.logo) }}
        </div>      
      </div>          
      </div>
      <div class="form-group mt-3">
        <div class="col-sm-offset-2 col-sm-10">
            <button type="submit" class="btn btn-success">{{ button_label|default('Enregistrer') }}</button>         
            <a href="{{ path('app_entreprise_index') }}" class="btn btn-danger">Revenir</a>
        </div>
      </div> 
    </div>
  </div>
</div>
{% endblock %}
