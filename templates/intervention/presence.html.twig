{% extends 'base.html.twig' %}  

{% block title %}Présences & absences {% endblock %}

{% block body %}

     <div class="card card-primary">
        <div class="card-header">
            <h3 class="card-title">Enregistrement de présence aux interventions</h3>
        </div>
        <div class="card card-body">

                <!-- /.card-header -->
                <div class="card-body">
                    {% for message in app.flashes('present') %}
                        <div class="primary">
                            {{ message }}
                        </div>
                    {% endfor %}
      

                    <form method="post">
                        <div class="row">
                            <div class="md-col-5">
                                <select name="intervention" id="intervention" class="select2" required="true">
                                    <option value=""> -- Choix de l'Intervention-- (Numero intervention- demande travail- date intervention)</option>
                                    {% for intervention in interventions %}
                                        <option value="{{ intervention.id }}"> {{ "%08d"|format(intervention.numintervention) }}-{{ intervention.demandetravaux }}-{{ intervention.dateintervention|date('d-m-Y')}}</option>
                                    {% endfor %}
                                </select>
                            </div>



                        </div>

                        <hr style="visibility: hidden" />  

                        <table id="example1" class="table table-bordered table-striped">
                            <thead>
                                <tr>
                                    <th>Nom et Prénom</th>
                                    <th>Adresse</th>
                                    <th>Présent</th>
                                </tr>
                            </thead>
                            <tbody>
                                    {% for technicien in techniciens %}
                                    <tr>
                                        <td> {{technicien.nometprenom|upper }}</td>
                                        <td> {{technicien.adresse|upper }}</td>
                                        <td>
                                        <input type="checkbox" name ="technicien[]" id="technicien[]" value="{{ technicien.id }}" title="Présent(e)"><br> 
                                        </td>
                                    </tr>
                                    {% endfor %}
                            </tbody>
                        </table>
                        <button class="btn btn-primary offset-6">{{ button_label|default('Valider') }}</button>
                        {# <a href="{{ path('app_activite_presence') }}" class="btn btn-success">Liste de présence</a> #}
                    </form>
                </div>
            </div>

        </div>

{% endblock %}
