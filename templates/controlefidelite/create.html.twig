{% extends 'base.html.twig' %}

{% block title %}controlejustesse{% endblock %}

{% block body %}  
 <div class="card-body">
                    <div class="row">
                      <div class="col-md-6 col-lg-4">
                          {{ form_start(form) }}

                        <div class="form-group">
                          <label for="email2">Code de l'instrument</label>
                       {{ form_widget(form.instrument) }}
                        </div> 
                        <div class="form-group">
                          <label for="email2">Point d'essai</label>
                       {{ form_widget(form.pointsdessai) }}
                        </div>
                        <div class="form-group">
                          <label for="password">Valeur nominale en <b>(kg)</b></label>
                            {{ form_widget(form.valeurnominale) }}

                        </div>
                        <div class="form-group form-inline">
                          <label class="col-md-3 col-form-label">Indication Lue en <b>(kg)</b></label>
                             {{ form_widget(form.indicationlue) }}
                        </div>
                      
                      </div>
                      <div class="col-md-6 col-lg-4">
                            <div class="form-group">
                          <label for="email2">Ecart relevé en <b>(kg)</b></label>
                       {{ form_widget(form.ecartreleve) }}
                        </div>
                        <div class="form-group">
                          <label for="password">Ecart maximal en <b>(kg)</b></label>
                            {{ form_widget(form.ecartmaximalreleve) }}

                        </div>
                      </div>                      
                      </div>
                     <div class="form-group mt-3">
            <div class="col-sm-offset-2 col-sm-10">
                <button type="submit" class="btn btn-success">{{ button_label|default('+ controle de fidélité') }}</button>
                <a href="{{ path('app_controlefidelite') }}" class="btn btn-danger">Revenir à l'accueil</a>
            </div>
        </div> 
                  </div>

{% endblock %}
