{% extends 'base.html.twig' %}

{% block title %}Technicien{% endblock %}

{% block body %}
 <div class="row">
              <div class="col-md-12">
              <a href="{{ path('app_technicien_new')}}"><button class="btn btn-secondary"><span class="btn-label"><i class="fa fa-plus"></i></span>Nouveau technicien</button></a>
                <div class="card">
                  <div class="card-header">
                    <div class="d-flex align-items-center">
                      <h4 class="card-title">Liste des Techniciens</h4>
                    </div>
                  </div>
                  <div class="card-body">
                    <!-- Modal -->
                 
                    <div class="table-responsive">
                      <table class="display table table-striped table-hover">
                        <thead>
                          <tr>
                            <th>Nom et prenom</th>
                            <th>Contact</th>
                            <th>Adresse</th>
                            <th style="width: 10%">Action</th>
                          </tr>
                        </thead>
                        <tfoot>
                          <tr>
                            <th>Nom et prenom</th>
                            <th>Contact</th>
                            <th>Adresse</th>
                            <th style="width: 10%">Action</th>                         
                          </tr>
                        </tfoot>
                        <tbody>
                         {% for techniciens in technicien %}
                        <tr>
                             <td>{{ techniciens.nometprenom}}</td>
                             <td>{{ techniciens.contact}}</td>
                             <td>{{ techniciens.adresse}}</td>
                             <td>
                              <div class="form-button-action">
                                <button class="btn btn-link btn-primary btn-lg">
                                  <a href="{{ path('app_technicien_edit',{'id': techniciens.id})}}" ><i class="fa fa-edit"></i></a>
                                </button> 
                                <button class="btn btn-link btn-danger btn-lg">
                                  <a href="{{ path('app_technicien_delete',{'id': techniciens.id})}}" ><i class="fa fa-trash"></i></a>
                                </button>
                              </div>
                            </td>
                        </tr>
                             {% endfor %}
                        </tbody>
                      </table>
                    </div>
                  </div>
                </div>
              </div>
            </div>
{% endblock %}

